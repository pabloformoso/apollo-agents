# ApolloAgents — environment variables
# Copy this file to .env and fill in your keys

# LLM provider — set at least one
# Anthropic (Claude) — recommended for the agent
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI — used for DALL-E 3 artwork generation and (optionally) the agent.
# Required when ANTHROPIC_API_KEY is not set, or to generate artwork.
# All four are required together if you use Azure at all.
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<your-gpt-deployment-name>

# Image generation (optional — without it, artwork is skipped cleanly).
# Image deployments often live on a DIFFERENT Azure resource than chat
# (different endpoint + key). Set IMAGE_ENDPOINT/IMAGE_API_KEY to override;
# if unset, the chat endpoint/key are reused.
# Models supported: dall-e-3, gpt-image-1, gpt-image-2.
# AZURE_OPENAI_IMAGE_DEPLOYMENT=<your-image-deployment-name>
# AZURE_OPENAI_IMAGE_ENDPOINT=https://<your-image-resource>.cognitiveservices.azure.com/
# AZURE_OPENAI_IMAGE_API_KEY=<separate-key-for-image-resource>

# Optional: pin Azure API versions (defaults are sensible for current deployments)
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_IMAGE_API_VERSION=2024-02-01

# Optional: override the agent model
# AGENT_MODEL=claude-opus-4-6

# Local inference via Ollama (no API key required)
# Install Ollama and run: ollama pull gemma4:4b
# AGENT_PROVIDER=ollama
# AGENT_MODEL=gemma4:4b
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Web UI (v2.0) — change this in production
JWT_SECRET=apollo-agents-change-me

# YouTube Live Chat integration (v2.7) — optional.
# Set all three to enable the "Connect YouTube" pill on /live; absence
# cleanly disables the feature (the /api/youtube/* endpoints return 404).
# Get the client id/secret from a Google Cloud OAuth 2.0 Client ID
# (https://console.cloud.google.com → APIs & Services → Credentials).
# The redirect URI MUST match what's registered in the OAuth client.
# Dev defaults assume the backend runs on port 4080 (the parallel v2.7
# dev stack); for production update to your deploy's public hostname.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=http://localhost:4080/api/youtube/oauth/callback

# Where the OAuth callback redirects the operator back to after consent.
# Defaults to http://localhost:4040 to match the parallel v2.7 dev stack.
# APOLLO_FRONTEND_URL=http://localhost:4040
